# ── AI APIs ──────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here          # console.groq.com → free
GEMINI_API_KEY=your_gemini_api_key_here      # aistudio.google.com → free

# ── Sports Data ──────────────────────────────────────────────────────────────
THESPORTSDB_API_KEY=123                      # free dev key
USE_MOCK=true                                # true = use mock_livescore.json

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440                      # 24 hours

# ── Infrastructure ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
DATABASE_URL=sqlite:///./data/events.db

# ── App ──────────────────────────────────────────────────────────────────────
BACKEND_URL=http://localhost:8000
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000

# ── Optional: Open-Meteo (bonus weather injection, no key needed) ─────────────
# OPENMETEO_ENABLED=true
